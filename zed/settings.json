{
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "vim_mode": false,
  "disable_ai": true,
  "soft_wrap": "editor_width",
  "agent": {
    "inline_assistant_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:latest",
      "enable_thinking": false,
    },
    "default_model": {
      "provider": "ollama",
      "model": "deepseek-coder:latest",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "theme": "Aura Dark",
  "theme_overrides": {
    "Aura Dark": {
      "editor.document_highlight.read_background": "#00000000",
      "editor.document_highlight.write_background": "#00000000",
      "border.variant": "#15141C",
      "border": "#15141C",
      "title_bar.background": "#15141C",
      "panel.background": "#15141C",
      "panel.focused_border": "#4E466E",
      "players": [
        {
          "cursor": "#BD9DFF",
        },
      ],
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment.doc": {
          "font_style": "italic",
        },
      },
    },
  },
  "icon_theme": "Catppuccin Frappé",
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
    "show_user_menu": false,
  },
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "status_bar": {
    "experimental.show": false,
    "active_language_button": true,
    "cursor_position_button": true,
    "line_endings_button": false,
  },
  "project_panel": {
    "dock": "right",
    "default_width": 400,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "scrollbar": {
    "show": "never",
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": false,
  },
  "indent_guides": {
    "enabled": true,
  },
  "ui_font_family": "Dank Mono",
  "ui_font_size": 20,
  "buffer_font_family": "Dank Mono",
  "buffer_font_size": 20,
  "buffer_font_features": {
    "calt": true,
  },
  "buffer_line_height": {
    "custom": 2,
  },
  "agent_buffer_font_size": 20,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "cursor_shape": "block",
  "cursor_blink": false,
  "selection_highlight": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "seed_search_query_from_cursor": "always",
  "current_line_highlight": "none",
  "show_whitespaces": "none",
  "tab_size": 2,
  "auto_indent": "none",
  "auto_indent_on_paste": false,
  "show_completions_on_input": true,
  "show_completion_documentation": false,
  "inline_code_actions": false,
  "lsp_document_colors": "none",
  "hover_popover_enabled": true,
  "format_on_save": "on",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "auto_update": false,
  "extend_comment_on_newline": false,
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,
  "when_closing_with_no_tabs": "keep_window_open",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "empty_tab",
  "session": {
    "restore_unsaved_buffers": false,
  },
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "enabled": false,
    },
  },
  "centered_layout": {
    "right_padding": 0.15,
    "left_padding": 0.15,
  },
  "languages": {
    "PHP": {
      "language_servers": ["intelephense", "!phpactor", "!phptools"],
      "formatter": {
        "external": {
          "command": "powershell.exe",
          "arguments": [
            "-NoProfile",
            "-Command",
            "$tmp = New-TemporaryFile; $input | Set-Content -LiteralPath $tmp; vendor/bin/pint $tmp --quiet; Get-Content -LiteralPath $tmp; Remove-Item $tmp",
          ],
        },
      },
    },
    "Blade": {
      "language_servers": [
        "html-language-server",
        "javascript-language-server",
        "css-lsp",
        "vtsls",
        "tailwindcss-language-server",
        "...",
      ],
      "tab_size": 4,
      "formatter": {
        "external": {
          "command": "powershell.exe",
          "arguments": ["-NoProfile", "-Command", "blade-formatter --stdin"],
        },
      },
    },
    "HTML": {
      "language_servers": [
        "html-language-server",
        "css-lsp",
        "vtsls",
        "tailwindcss-language-server",
        "...",
      ],

      "formatter": {
        "external": {
          "command": "powershell.exe",
          "arguments": ["-NoProfile", "-Command", "blade-formatter --stdin"],
        },
      },
    },
  },
}
